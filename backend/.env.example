# Keep credentials on the server only. Never expose them as VITE_* browser variables.
# Azure OpenAI v1 Responses API (recommended for this project)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.4

# Optional fallback: public OpenAI Responses API. Do not configure both providers.
# OPENAI_API_KEY=
# ARCHITECT_MODEL=gpt-5.6
# RTL_MODEL=gpt-5.6
CORS_ORIGIN=http://localhost:3000
